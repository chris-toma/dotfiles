alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias md='x(){ mkdir "$1"; cd "$1"; }; x'
alias k=kubectl
alias t=tmux
alias tp=tmuxp
alias c=clear
alias d=docker
alias e=exit
alias n=nvim
alias v='fd --type f --hidden --exclude .git | fzf-tmux -p --reverse | xargs nvim'
alias y=yazi
alias c8-start="$HOME/.tmuxp/start-all.sh"
alias l='eza -la --icons --git'
alias ls='eza --icons'
alias ll='eza -la --icons --git --tree --level=2'
alias lg=lazygit
alias mockery2=~/projects/captiv8/go-microservices/bin/mockery

# OS-specific aliases
case "$(uname -s)" in
  Darwin)
    alias listen='lsof -i -P -n | grep LISTEN'
    alias mollie_env="$HOME/Library/Application Support/Local/ssh-entry/VnAUZONPR.sh ; exit;"
    ;;
  Linux)
    alias listen='ss -tlnp'
    ;;
esac

fut() {
    (cd "$HOME/projects/captiv8/go-microservices" && ./fut "$@")
}
